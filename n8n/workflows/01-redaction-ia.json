    {
      "id": "extract-content",
      "name": "Code - Extract Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2220,
        300
      ],
      "parameters": {
        "jsCode": "const claudeResponse = $('Claude API - Generate').item.json;\nconst content = claudeResponse.content?.[0]?.text || '';\n\nif (!content) {\n  throw new Error('Claude n\\'a retourn\u00e9 aucun contenu');\n}\n\n// Version number\nconst maxVersionData = $('Supabase - Get Max Version').item.json;\nconst maxVersion = Array.isArray(maxVersionData) && maxVersionData.length > 0\n  ? (maxVersionData[0].version_number || 0)\n  : 0;\nconst versionNumber = maxVersion + 1;\n\nconst postId       = $('Webhook - generate-post').item.json.body.post_id;\nconst orgId        = $('Webhook - generate-post').item.json.body.organization_id;\n\nreturn [{\n  json: { content, versionNumber, postId, orgId }\n}];"
      }
    },
