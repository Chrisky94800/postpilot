    {
      "id": "build-prompt",
      "name": "Code - Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        300
      ],
      "parameters": {
        "jsCode": "const post = $('Supabase - Get Post').item.json[0];\nconst bp   = $('Supabase - Get Brand Profile').item.json[0] || {};\n\n// \u2500\u2500 Source content\nlet rawSource = '';\nif (post.source_type === 'url') {\n  try {\n    const scraped = $('Supabase - Scrape URL').item.json;\n    rawSource = `Titre : ${scraped.title}\\n\\n${scraped.content}`;\n  } catch(e) {\n    rawSource = post.source_url || '';\n  }\n} else if (post.source_content) {\n  rawSource = post.source_content;\n} else if (post.content) {\n  rawSource = post.content;\n}\n\n// D\u00e9tecte [IMAGE:mime]base64\nconst imageMatch = rawSource.match(/\\[IMAGE:([^\\]]+)\\]([\\s\\S]+)$/);\nlet isImage = false, imageMimeType = '', imageBase64 = '', instructionsPrefix = '';\n\nif (imageMatch) {\n  isImage = true;\n  imageMimeType = imageMatch[1];\n  imageBase64 = imageMatch[2].trim();\n  const instrMatch = rawSource.match(/^Instructions\\s*:\\s*([\\s\\S]+?)\\n\\n---\\n\\n\\[IMAGE:/);\n  if (instrMatch) instructionsPrefix = instrMatch[1].trim().slice(0, 500);\n} else {\n  rawSource = rawSource.slice(0, 4000);\n}\n\n// \u2500\u2500 Brand profile\nconst tone = Array.isArray(bp.tone) ? bp.tone.join(', ') : (bp.tone || 'professionnel');\nconst keywords = Array.isArray(bp.keywords) ? bp.keywords.join(', ') : '';\nconst keywordsAvoid = Array.isArray(bp.keywords_avoid) ? bp.keywords_avoid.join(', ') : '';\nconst hashtags = Array.isArray(bp.hashtags_preferred) ? bp.hashtags_preferred.join(' ') : '';\nconst hashtagStrategy = bp.hashtag_strategy || 'medium';\nconst ctas = Array.isArray(bp.ctas_preferred) ? bp.ctas_preferred.join(', ') : '';\nconst examples = Array.isArray(bp.example_posts) && bp.example_posts.length > 0\n  ? bp.example_posts.slice(0,2).map((p, i) => `Exemple ${i+1}:\\n${String(p).slice(0,400)}`).join('\\n\\n')\n  : 'Aucun exemple fourni.';\nconst lengthMap = { short: '800-1200', medium: '1200-2000', long: '2000-3000' };\nconst targetChars = lengthMap[bp.post_length] || '1200-2000';\nconst emojiMap = { 0: 'Aucun emoji', 1: 'Tr\u00e8s peu (1-2 max)', 2: 'Mod\u00e9r\u00e9 (3-5)', 3: 'Beaucoup (6+)' };\nconst emojiUsage = emojiMap[bp.emoji_style] || 'Mod\u00e9r\u00e9 (3-5)';\n\nconst systemPrompt = `Tu es un expert en r\u00e9daction de posts LinkedIn pour ${bp.company_name || 'cette entreprise'}, une entreprise de ${bp.industry || 'ce secteur'}.\nTu r\u00e9diges des contenus professionnels, engageants et authentiques qui refl\u00e8tent la voix de la marque.\n\nProfil de marque :\n- Entreprise : ${bp.company_name} \u2014 ${(bp.description || '').slice(0,200)}\n- Audience cible : ${bp.target_audience || 'professionnels'}\n- Ton : ${tone}\n- Mots-cl\u00e9s \u00e0 int\u00e9grer : ${keywords || 'aucun sp\u00e9cifi\u00e9'}\n- Mots-cl\u00e9s interdits : ${keywordsAvoid || 'aucun'}\n- Emojis : ${emojiUsage}\n- Longueur cible : ~${targetChars} caract\u00e8res\n- Hashtags : strat\u00e9gie ${hashtagStrategy}, pr\u00e9f\u00e9r\u00e9s : ${hashtags || 'aucun'}\n- CTA pr\u00e9f\u00e9r\u00e9s : ${ctas || 'aucun sp\u00e9cifi\u00e9'}\n\nExemples de posts appr\u00e9ci\u00e9s :\n${examples}`;\n\n// \u2500\u2500 Build messages\nlet messages;\n\nif (isImage) {\n  let textInstruction;\n  if (instructionsPrefix) {\n    textInstruction = `\u00c9TAPE 1 \u2014 Lis attentivement l'image et transcris mentalement tout le texte visible.\\n\\n\u00c9TAPE 2 \u2014 Applique EXACTEMENT cette instruction sur ce texte :\\n\"${instructionsPrefix}\"\\n\\n\u00c9TAPE 3 \u2014 Formate le r\u00e9sultat en post LinkedIn :\\n- Langue : fran\u00e7ais\\n- Longueur : ~${targetChars} caract\u00e8res\\n- Emojis : ${emojiUsage}\\n- Hashtags en fin de post : ${hashtags || 'selon le sujet'}\\n- Signature : ${bp.signature || 'aucune'}\\n\\nIMPORTANT : Base-toi UNIQUEMENT sur le contenu visible dans l'image.`;\n  } else {\n    textInstruction = `\u00c9TAPE 1 \u2014 Lis attentivement l'image et transcris mentalement tout le texte visible.\\n\\n\u00c9TAPE 2 \u2014 R\u00e9dige un post LinkedIn professionnel bas\u00e9 sur ce contenu.\\n\\nConsignes :\\n1. Accroche percutante en premi\u00e8re ligne\\n2. D\u00e9veloppement structur\u00e9 avec sauts de ligne\\n3. Conclusion avec CTA\\n4. Hashtags en fin de post\\n5. Longueur : ~${targetChars} caract\u00e8res\\n6. Langue : fran\u00e7ais\\n\\nIMPORTANT : Base-toi UNIQUEMENT sur le contenu visible dans l'image.`;\n  }\n  messages = [{\n    role: 'user',\n    content: [\n      { type: 'image', source: { type: 'base64', media_type: imageMimeType, data: imageBase64 } },\n      { type: 'text', text: textInstruction }\n    ]\n  }];\n} else {\n  const userPrompt = `Source du post :\\n- Type : ${post.source_type || 'manual'}\\n- Contenu : ${rawSource}\\n\\nConsignes :\\n1. Accroche percutante en premi\u00e8re ligne (hook avant \"...voir plus\")\\n2. D\u00e9veloppement structur\u00e9 avec sauts de ligne\\n3. Conclusion avec CTA\\n4. Hashtags en fin de post\\n5. Longueur : ~${targetChars} caract\u00e8res\\n6. Langue : fran\u00e7ais\\n\\nG\u00e9n\u00e8re le post LinkedIn.`;\n  messages = [{ role: 'user', content: userPrompt }];\n}\n\n// Pr\u00e9-s\u00e9rialiser le body Claude pour \u00e9viter les probl\u00e8mes de s\u00e9rialisation n8n\n// avec les objets imbriqu\u00e9s (notamment le base64 image)\nconst claudeRequestBody = JSON.stringify({\n  model: 'claude-sonnet-4-6',\n  max_tokens: 1500,\n  system: systemPrompt,\n  messages: messages\n});\n\nreturn [{ json: { claudeRequestBody } }];"
      }
    },
