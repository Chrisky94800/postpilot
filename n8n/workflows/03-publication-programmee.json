    {
      "id": "build-linkedin-payload",
      "name": "Code - Build LinkedIn Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ],
      "parameters": {
        "jsCode": "// Merge post data (from split node) with token data (from get-token)\nconst post = $('Code - Split Posts').item.json;\nconst platforms = $json; // array from get-token\n\n// Check if platform exists and is active\nif (!Array.isArray(platforms) || platforms.length === 0) {\n  return [{ json: { ...post, tokenError: true, tokenErrorMsg: 'No LinkedIn account connected for this organization' } }];\n}\n\nconst platform = platforms[0];\n\nif (!platform.is_active) {\n  return [{ json: { ...post, tokenError: true, tokenErrorMsg: 'LinkedIn account is inactive' } }];\n}\n\n// Check token expiry\nconst expiresAt = new Date(platform.token_expires_at);\nif (expiresAt <= new Date()) {\n  return [{ json: { ...post, tokenError: true, tokenErrorMsg: 'LinkedIn access token expired' } }];\n}\n\nconst tokens = platform.oauth_tokens;\nconst accessToken = tokens.access_token;\n\n// Build author URN\nconst authorUrn = platform.platform_user_id || `urn:li:person:${tokens.linkedin_person_id}`;\n\n// Build LinkedIn ugcPosts body\nconst linkedinBody = {\n  author: authorUrn,\n  lifecycleState: 'PUBLISHED',\n  specificContent: {\n    'com.linkedin.ugc.ShareContent': {\n      shareCommentary: { text: post.content },\n      shareMediaCategory: 'NONE'\n    }\n  },\n  visibility: {\n    'com.linkedin.ugc.MemberNetworkVisibility': 'PUBLIC'\n  }\n};\n\nreturn [{ json: { ...post, tokenError: false, accessToken, authorUrn, linkedinBody: JSON.stringify(linkedinBody) } }];"
      }
    },
