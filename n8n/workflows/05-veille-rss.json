      "name": "Supabase - Get Active Feeds",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300],
      "parameters": {
        "method": "GET",
        "url": "https://tplgbskcvimemwtwpxyk.supabase.co/rest/v1/rss_feeds?is_active=eq.true&select=id,organization_id,url,title&limit=100",
