        "jsonBody": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 256, messages: [{ role: 'user', content: 'Marque: ' + (Array.isArray($('Supabase - Get Brand Profile').item.json) && $('Supabase - Get Brand Profile').item.json.length > 0 ? ($('Supabase - Get Brand Profile').item.json[0].description || '') : '') + '. Mots-clés: ' + (Array.isArray($('Supabase - Get Brand Profile').item.json) && $('Supabase - Get Brand Profile').item.json.length > 0 ? JSON.stringify($('Supabase - Get Brand Profile').item.json[0].keywords || []) : '[]') + '. Article: \"' + $('Code - Pick Latest & Merge Feed Info').item.json.article_title + '\". Résumé: \"' + $('Code - Pick Latest & Merge Feed Info').item.json.article_summary.slice(0, 300) + '\". Cet article est-il pertinent pour créer du contenu LinkedIn ? Réponds UNIQUEMENT en JSON: {\"relevant\": true/false, \"reason\": \"...\"}' }] }) }}",
