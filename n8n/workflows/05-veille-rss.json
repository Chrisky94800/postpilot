        "jsonBody": "={{ JSON.stringify({ action: 'rss_article_found', organization_id: $('Code - Pick Latest & Merge Feed Info').item.json.organization_id, article_title: $('Code - Pick Latest & Merge Feed Info').item.json.article_title, article_url: $('Code - Pick Latest & Merge Feed Info').item.json.article_url, article_summary: $('Code - Pick Latest & Merge Feed Info').item.json.article_summary, feed_title: $('Code - Pick Latest & Merge Feed Info').item.json.feed_title }) }}",
