# PostPilot — Variables d'environnement
# Copiez ce fichier en .env et renseignez vos valeurs.
# NE JAMAIS commiter le fichier .env

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── N8N Webhooks ──────────────────────────────────────────────────────────────
# URL de base de votre instance n8n (sans slash final)
VITE_N8N_WEBHOOK_BASE_URL=https://votre-n8n.example.com
# Clé partagée pour authentifier les appels (header X-API-Key)
VITE_N8N_API_KEY=votre_cle_secrete_n8n

# ── App URL (utilisée pour les redirections OAuth) ─────────────────────────────
VITE_APP_URL=https://postpilot.lovable.app
