# Supabase
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx...

# N8N Webhooks
VITE_N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com
VITE_N8N_WEBHOOK_GENERATE_POST=/webhook/generate-post
VITE_N8N_WEBHOOK_REVISE_POST=/webhook/revise-post
VITE_N8N_WEBHOOK_SCRAPE_URL=/webhook/scrape-url
VITE_N8N_WEBHOOK_TRANSCRIBE=/webhook/transcribe-vocal
VITE_N8N_WEBHOOK_LINKEDIN_CONNECT=/webhook/linkedin-connect
VITE_N8N_API_KEY=your-shared-api-key

# LinkedIn App (créée sur developer.linkedin.com)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://your-supabase-url/functions/v1/linkedin-oauth-callback

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_xxx

# Backend-only keys (used in n8n + Edge Functions, NOT in frontend)
# SUPABASE_SERVICE_ROLE_KEY=eyJxxx...
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-proj-xxx
# RESEND_API_KEY=re_xxx
